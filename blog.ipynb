   "source": [
    "from langgraph.graph import StateGraph,START,END\n",
    "import os\n",
    "from langchain_google_genai import ChatGoogleGenerativeAI\n",
    "from typing import TypedDict\n",
    "from dotenv import load_dotenv"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 28,
   "metadata": {},
   "outputs": [],
   "source": [
    "load_dotenv()\n",
    "import os\n",
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 29,
   "metadata": {},
   "outputs": [],
   "source": [
    "llm = ChatGoogleGenerativeAI(\n",
    "    model = \"gemini-2.5-flash\",\n",
    "    temperature = 0\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 30,
   "metadata": {},
   "outputs": [],
   "source": [
    "class BlogState(TypedDict):\n",
    "    title:str\n",
    "    outline:str\n",
    "    content:str"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 31,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_outline(state: BlogState) -> BlogState:\n",
    "    #fetch the tilte \n",
    "\n",
    "    title = state[\"title\"]\n",
    "    #call for llm\n",
    "\n",
    "    prompt = f\"Create a detailed blog outline for {title}\"\n",
    "\n",
    "    outline = llm.invoke(prompt).content\n",
    "    # update state \n",
    "    state[\"outline\"] = outline\n",
    "\n",
    "    return state"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 32,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_blog(state:BlogState) -> BlogState:\n",
    "    #fetch title and outline\n",
    "    title = state['title']\n",
    "    outline = state['outline']\n",
    "    # call for llm \n",
    "    prompt = f\"write a detailed blog on the topic - {title} using the following outline \\n {outline}\"\n",
    "    content = llm.invoke(prompt).content\n",
    "    # update the state \n",
    "    state[\"content\"] = content\n",
    "    return state\n",
    "\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "metadata": {},
   "outputs": [],
   "source": [
    "graph = StateGraph(BlogState)\n",
    "graph.add_node('create_outline',create_outline)\n",
    "graph.add_node('create_blog',create_blog)\n",
    "graph.add_edge(START ,'create_outline' )\n",
    "graph.add_edge('create_outline' ,'create_blog' )\n",
    "graph.add_edge('create_blog' , END)\n",
    "workflow = graph.compile()\n"
   ]
